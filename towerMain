-- Comprehensive Viewport Frame Regeneration Engine
generateViewportPreview = function()
    worldModel:ClearAllChildren()
    
    local srcCharacter = LocalPlayer.Character
    if not srcCharacter then return end
    
    srcCharacter.Archivable = true
    uiCloneModel = srcCharacter:Clone()
    srcCharacter.Archivable = false
    
    uiCloneModel.Parent = worldModel
    
    local hrp = uiCloneModel:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = CFrame.new(0, 0, 0)
        viewCamera.CFrame = CFrame.new(Vector3.new(0, 2.2, -5.5), hrp.Position + Vector3.new(0, 0.4, 0))
    end
    
    -- Neon simulation fallback profile for viewport limitations
    if espActive then
        for _, part in ipairs(uiCloneModel:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Material = Enum.Material.Neon
                part.Color = espColorSetting
                part.Transparency = 0.25
            end
        end
    end

    -- Mock UI Rig Line Render Trace
    if tracersActive then
        local mockTracer = Instance.new("Part")
        mockTracer.Name = "MockTracer"
        mockTracer.Material = Enum.Material.Neon
        mockTracer.Anchored = true
        mockTracer.CanCollide = false
        mockTracer.Color = tracerColorSetting
        mockTracer.Parent = worldModel
        
        local startPos = Vector3.new(0, -1, -3)
        local endPos = hrp and hrp.Position or Vector3.new(0, 0, 0)
        local distance = (endPos - startPos).Magnitude
        
        mockTracer.Size = Vector3.new(0.04, 0.04, distance)
        mockTracer.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -distance/2)
    end

    mockOverheadFrame.Visible = (nameplatesActive or healthBarsActive)
    mockNameLabel.Visible = nameplatesActive
    mockHealthBG.Visible = healthBarsActive
end

task.spawn(function()
    if LocalPlayer.Character then generateViewportPreview() end
    LocalPlayer.CharacterAdded:Connect(generateViewportPreview)
end)

