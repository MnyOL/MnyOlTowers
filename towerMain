local function updateToggleVisual(btn, stroke, state)
    local color = state and Color3.fromRGB(40, 230, 110) or Color3.fromRGB(240, 50, 50)
    btn.Text = state and "ON" or "OFF"
    TweenService:Create(btn, TweenInfo.new(0.15), {TextColor3 = color}):Play()
    TweenService:Create(stroke, TweenInfo.new(0.15), {Color = color}):Play()
end

local function createSlider(parent, textPrefix, yOffset, min, max, default, callback)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -10, 0, 45)
    container.Position = UDim2.new(0, 0, 0, yOffset)
    container.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.Text = textPrefix .. ": " .. tostring(default)
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left

    local sliderBar = Instance.new("TextButton", container)
    sliderBar.Size = UDim2.new(1, -10, 0, 6)
    sliderBar.Position = UDim2.new(0, 0, 0, 25)
    sliderBar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    sliderBar.Text = ""
    Instance.new("UICorner", sliderBar).CornerRadius = UDim.new(0, 3)

    local fill = Instance.new("Frame", sliderBar)
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = COLOR_NEON_ORANGE
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

    local knob = Instance.new("Frame", sliderBar)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new((default - min) / (max - min), -6, 0.5, -6)
    knob.BackgroundColor3 = COLOR_TEXT_LIGHT
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", knob).Color = COLOR_NEON_ORANGE

    local activeDragging = false

    local function evaluateInput(input)
        local totalWidth = sliderBar.AbsoluteSize.X
        local relativeX = input.Position.X - sliderBar.AbsolutePosition.X
        local percentage = math.clamp(relativeX / totalWidth, 0, 1)
        
        local computedValue = math.floor(min + (max - min) * percentage)
        label.Text = textPrefix .. ": " .. tostring(computedValue)
        
        fill.Size = UDim2.new(percentage, 0, 1, 0)
        knob.Position = UDim2.new(percentage, -6, 0.5, -6)
        
        callback(computedValue)
    end

    sliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            activeDragging = true
            evaluateInput(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if activeDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            evaluateInput(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            activeDragging = false
        end
    end)
end

