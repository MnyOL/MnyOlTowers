-- Physics Step Loop (Noclip, Speed, Jump Power Enforcement)
RunService.Stepped:Connect(function()
    if not LocalPlayer.Character then return end
    local character = LocalPlayer.Character
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    -- Handle standard attribute enforcements
    if humanoid then
        if speedBoostActive and humanoid.WalkSpeed ~= currentSpeedValue then
            humanoid.WalkSpeed = currentSpeedValue
        end
        if jumpBoostActive then
            humanoid.UseJumpPower = true
            if humanoid.JumpPower ~= currentJumpValue then
                humanoid.JumpPower = currentJumpValue
            end
        end
    end
    
    -- Handle dynamic Noclip physics layer override
    if noclipActive then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- Frame Render Step Loop (Flight Engine & Screen Space Drawing Layers)
RunService.RenderStepped:Connect(function(dt)
    if not LocalPlayer.Character then return end
    local character = LocalPlayer.Character
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    -- 1. REAL-TIME FLIGHT CONTROLLER MODULE
    if flyActive and hrp and humanoid then
        humanoid.PlatformStand = true
        local moveDir = Vector3.new(0, 0, 0)
        
        -- Calculate camera relative movement coordinates
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
        
        -- Cancel natural physics falling and apply custom displacement vectors
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        if moveDir.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame + (moveDir.Unit * currentFlySpeed * dt)
        end
    elseif humanoid and humanoid.PlatformStand and not flyActive then
        humanoid.PlatformStand = false
    end

    -- 2. TARGET SCREEN RENDER PIPELINE (Tracers & Overheads)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local tChar = player.Character
            local tHrp = tChar:FindFirstChild("HumanoidRootPart")
            local tHead = tChar:FindFirstChild("Head")
            local tHumanoid = tChar:FindFirstChildOfClass("Humanoid")
            
            -- Draw 2D Vector Target Lines
            local tracerFrame = tracerContainer:FindFirstChild(player.Name)
            if tracersActive and tHrp then
                local screenPos, onScreen = camera:WorldToViewportPoint(tHrp.Position)
                if onScreen then
                    if not tracerFrame then
                        tracerFrame = Instance.new("Frame", tracerContainer)
                        tracerFrame.Name = player.Name
                        tracerFrame.AnchorPoint = Vector2.new(0.5, 0.5)
                        tracerFrame.BorderSizePixel = 0
                    end
                    
                    local startPos = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                    local endPos = Vector2.new(screenPos.X, screenPos.Y)
                    local distance = (endPos - startPos).Magnitude
                    local angle = math.deg(math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X))
                    
                    tracerFrame.Size = UDim2.new(0, distance, 0, 1.5)
                    tracerFrame.Position = UDim2.new(0, (startPos.X + endPos.X) / 2, 0, (startPos.Y + endPos.Y) / 2)
                    tracerFrame.Rotation = angle
                    tracerFrame.BackgroundColor3 = tracerColorSetting
                    tracerFrame.Visible = true
                else
                    if tracerFrame then tracerFrame.Visible = false end
                end
            else
                if tracerFrame then tracerFrame:Destroy() end
            end
            
            -- Draw Overhead HUD Assemblies
            local billboard = tChar:FindFirstChild("HubOverhead")
            if (nameplatesActive or healthBarsActive) and tHead then
                if not billboard then
                    billboard = Instance.new("BillboardGui")
                    billboard.Name = "HubOverhead"
                    billboard.Size = UDim2.new(0, 130, 0, 35)
                    billboard.AlwaysOnTop = true
                    billboard.ExtentsOffset = Vector3.new(0, 2.5, 0)
                    billboard.Adornee = tHead
                    billboard.Parent = tChar
                    
                    local nameLabel = Instance.new("TextLabel", billboard)
                    nameLabel.Name = "PlayerName"
                    nameLabel.Size = UDim2.new(1, 0, 0, 14)
                    nameLabel.BackgroundTransparency = 1
                    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameLabel.Font = Enum.Font.GothamBold
                    nameLabel.TextSize = 11
                    nameLabel.TextStrokeTransparency = 0
                    
                    local healthBG = Instance.new("Frame", billboard)
                    healthBG.Name = "HealthBG"
                    healthBG.Size = UDim2.new(0, 60, 0, 4)
                    healthBG.Position = UDim2.new(0.5, -30, 0, 16)
                    healthBG.BackgroundColor3 = Color3.fromRGB(60, 10, 10)
                    healthBG.BorderSizePixel = 0
                    
                    local healthFill = Instance.new("Frame", healthBG)
                    healthFill.Name = "HealthFill"
                    healthFill.Size = UDim2.new(1, 0, 1, 0)
                    healthFill.BackgroundColor3 = Color3.fromRGB(40, 230, 110)
                    healthFill.BorderSizePixel = 0
                end
                
                billboard.PlayerName.Text = player.Name
                billboard.PlayerName.Visible = nameplatesActive
                billboard.HealthBG.Visible = healthBarsActive
                
                if tHumanoid then
                    local hpPercent = math.clamp(tHumanoid.Health / tHumanoid.MaxHealth, 0, 1)
                    billboard.HealthBG.HealthFill.Size = UDim2.new(hpPercent, 0, 1, 0)
                end
            else
                if billboard then billboard:Destroy() end
            end
        end
    end
    
    -- Cleanup residual tracers for dropped connections
    for _, child in ipairs(tracerContainer:GetChildren()) do
        local targetPlayer = Players:FindFirstChild(child.Name)
        if not targetPlayer or not targetPlayer.Character then
            child:Destroy()
        end
    end
end)

-- Character event listener initialization pipeline
local function listenToPlayer(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(character)
        task.wait(0.1)
        if espActive then applyInGameHighlight(character) end
    end)
    player.CharacterRemoving:Connect(clearVisualsFromCharacter)
end

Players.PlayerAdded:Connect(listenToPlayer)
for _, p in ipairs(Players:GetPlayers()) do listenToPlayer(p) end

